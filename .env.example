# 127.0.0.1 (not localhost): on Windows, localhost may resolve to ::1 where
# Docker's port mappings are not reachable (wslrelay holds [::1] ports)
DATABASE_URL=postgresql://navalia:navalia@127.0.0.1:5432/navalia
REDIS_URL=redis://127.0.0.1:6379/0
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
PLAN_PRICE_CENTS=9900
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Transcription model for WhatsApp voice notes (gpt-4o-mini-transcribe | whisper-1)
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
EVOLUTION_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=navalia-dev-key
EVOLUTION_WEBHOOK_TOKEN=dev-webhook-token
# Webhook URL reachable FROM the Evolution container.
# Dev: http://host.docker.internal:3000 (container→host bridge).
# Prod: set to your public domain, e.g. https://navalia.app
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:3000
