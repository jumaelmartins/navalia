# ─── Navalia production environment ──────────────────────────────────────────
# Copy to .env.prod, fill every value, NEVER commit .env.prod to git.
# See docs/DEPLOY.md for the full provisioning runbook.

# ── Domain ───────────────────────────────────────────────────────────────────
# The public domain where Navalia is hosted (no protocol prefix).
# Caddy provisions TLS automatically once DNS is pointed at this server.
DOMAIN=navalia.example.com

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://navalia.example.com
BETTER_AUTH_URL=https://navalia.example.com

# ── Auth (CRITICAL — rotate this before first boot) ──────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=REPLACE_WITH_openssl_rand_-base64_32_output

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=navalia
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD
POSTGRES_DB=navalia
DATABASE_URL=postgresql://navalia:REPLACE_WITH_STRONG_RANDOM_PASSWORD@postgres:5432/navalia

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Stripe (use live keys in production; test keys for staging) ──────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
PLAN_PRICE_CENTS=9900

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Evolution API (WhatsApp) ─────────────────────────────────────────────────
# Reachable FROM the app container on the internal Docker network.
EVOLUTION_URL=http://evolution:8080
# Strong random key — set this in Evolution's environment too (AUTHENTICATION_API_KEY).
EVOLUTION_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
EVOLUTION_WEBHOOK_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN
# Evolution calls this URL when a WhatsApp message arrives.
# In prod, Evolution and app share the internal Docker network — no public URL needed.
EVOLUTION_WEBHOOK_URL=http://app:3000
